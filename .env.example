# Dashboard Authentication
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme

# Data Source Configuration
# Set LOCAL_MODE=false for cloud deployment (reads from Gist)
# Set LOCAL_MODE=true for local deployment (reads from local SQLite)
LOCAL_MODE=false

# GitHub Gist Integration (for cloud mode)
GIST_ID=your_gist_id_here
GITHUB_TOKEN=your_github_token_here

# Optional: Override port
# PORT=5000